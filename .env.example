# OpenAI-compatible API (OpenAI, Groq, DeepSeek, Tongyi, etc.)
# Never commit real keys — copy to .env and fill in locally
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Groq example:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.1-8b-instant

# CORS allowed frontend origin(s)
CORS_ORIGINS=http://localhost:3000

# --- Optional conversion tuning ---
CHUNK_MAX_CHARS=400
MAX_DIALOGUES_PER_PART=5
OPENAI_MAX_TOKENS=2048
COVERAGE_MAX_RETRIES=2
SCENE_MAX_CHARS=480
CHUNK_DELAY_SEC=0
